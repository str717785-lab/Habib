<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1">

  <!-- ═══ STATIC PAGES ═══════════════════════════════════ -->
  <url>
    <loc>https://cineinsight.info/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/privacy-policy</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/terms</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>

  <!-- ═══ CATEGORY PAGES (SSR — Google can index these) ══ -->
  <!--
    Add one <url> per category that exists in your Firebase data.
    The slug must match the category field value (lowercased, spaces→hyphens).
    e.g.  category "Hot"     →  /category/hot
          category "Action"  →  /category/action
          category "Drama"   →  /category/drama
  -->
  <url>
    <loc>https://cineinsight.info/category/hot</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/trending</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/action</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/drama</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/comedy</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/thriller</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/romance</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://cineinsight.info/category/horror</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <!--
  ═══ VIDEO PAGES ════════════════════════════════════════
  Add one <url> per video. Replace VIDEO_ID, TITLE etc.

  <url>
    <loc>https://cineinsight.info/video?id=VIDEO_ID</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
    <video:video>
      <video:thumbnail_loc>THUMBNAIL_URL</video:thumbnail_loc>
      <video:title>TITLE</video:title>
      <video:description>DESCRIPTION</video:description>
      <video:publication_date>YYYY-MM-DD</video:publication_date>
    </video:video>
  </url>
  ═══════════════════════════════════════════════════════ -->

</urlset>
